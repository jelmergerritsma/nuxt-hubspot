{
  "name": "nuxt-hubspot",
  "version": "0.0.2",
  "description": "HubSpot analytics integration for Nuxt with typesafe event tracking and DevTools panel",
  "packageManager": "pnpm@11.2.2",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jelmergerritsma/nuxt-hubspot.git"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "hubspot",
    "analytics",
    "tracking",
    "devtools"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build && npm run client:build",
    "client:build": "nuxi generate client",
    "client:dev": "nuxi dev client --port 3300",
    "dev": "npm run play:dev",
    "dev:prepare": "nuxt-module-build --stub && nuxi prepare client",
    "prepare": "nuxi prepare client",
    "play:dev": "nuxi dev playground",
    "play:prod": "npm run prepack && nuxi dev playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@analytics/hubspot": "^0.5.1",
    "@nuxt/devtools-kit": "^3.2.4",
    "@nuxt/kit": "^4.4.8",
    "analytics": "^0.8.14",
    "sirv": "^3.0.2"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.23",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/devtools-ui-kit": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "changelogen": "^0.6.2",
    "eslint": "^10.4.1",
    "nuxt": "^4.4.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
